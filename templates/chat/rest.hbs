{{!--
  Rest chat card.
  Shows: actor + rest type, HP heal payload, conditions cleared (if any),
  class-specific resets (Cleric fumble threshold, Bard JoT slots).
--}}
<div class="flail-card cast-card rest-card rest-{{kind}}">

  <header class="card-header">
    <img class="actor-img" src="{{actor.img}}" />
    <span class="actor-name">{{actor.name}}</span>
    <h3>
      <i class="fas fa-bed"></i>
      {{localize label}}
    </h3>
  </header>

  {{!-- Heal payload --}}
  <div class="cast-description heal-payload">
    {{#if healToFull}}
      {{#if healAmount}}
      <strong>{{localize "FLAIL.Rest.HealedToFull"}}:</strong>
      +{{healAmount}} hp ({{hpBefore}} → {{hpAfter}} / {{hpMax}})
      {{else}}
      <strong>{{localize "FLAIL.Rest.AlreadyFull"}}.</strong>
      {{/if}}
    {{else}}
      {{#if healAmount}}
      <strong>{{localize "FLAIL.Rest.Healed"}}:</strong>
      +{{healAmount}} hp <span class="rest-formula">({{healFormula}})</span>
      — {{hpBefore}} → {{hpAfter}} / {{hpMax}}
      {{else}}
      <em>{{localize "FLAIL.Rest.NoHeal"}}</em>
      {{/if}}
    {{/if}}
  </div>

  {{!-- Conditions cleared --}}
  {{#if conditionsCleared.length}}
  <div class="rest-conditions-cleared">
    <header><i class="fas fa-check"></i> {{localize "FLAIL.Rest.ConditionsCleared"}}</header>
    <ul>
      {{#each conditionsCleared as |name|}}
      <li>{{name}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{!-- Cleric: fumble threshold reset --}}
  {{#if fumbleReset}}
  <div class="rest-reset">
    <i class="fas fa-rotate-left"></i>
    {{localize "FLAIL.Rest.FumbleReset"}}:
    <strong>{{fumbleReset.from}} → {{fumbleReset.to}}</strong>
  </div>
  {{/if}}

  {{!-- Bard: Jack of All Trades reset --}}
  {{#if jotReset}}
  <div class="rest-reset">
    <i class="fas fa-rotate-left"></i>
    {{localize "FLAIL.Rest.JackOfTradesReset"}}
  </div>
  {{/if}}

  {{!-- Bard: instrument used-out flags cleared --}}
  {{#if instrumentsReset}}
  <div class="rest-reset">
    <i class="fas fa-music"></i>
    {{localize "FLAIL.Rest.InstrumentsReset"}}
  </div>
  {{/if}}

  {{!-- Wizard: Mana refilled --}}
  {{#if manaReset}}
  <div class="rest-reset">
    <i class="fas fa-flask"></i>
    {{localize "FLAIL.Rest.ManaRefilled"}}
    <strong>{{manaReset.from}} → {{manaReset.to}}</strong>
  </div>
  {{/if}}
</div>
