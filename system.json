{
  "id": "flail",
  "title": "FLAIL!",
  "description": "An old-school fantasy brawler by Andre Novoa. Roll-under saves, poker-dice combat, slot-based inventory, eight wildly different classes.",
  "version": "0.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "14",
    "maximum": "14"
  },
  "authors": [
    {
      "name": "Reuben Taylor",
      "url": "https://github.com/reubentaylor"
    }
  ],
  "esmodules": ["module/flail.mjs"],
  "styles": ["styles/flail.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [],
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "primaryTokenAttribute": "hp",
  "documentTypes": {
    "Actor": {
      "character": { "htmlFields": ["biography", "notes"] },
      "npc":       { "htmlFields": ["description"] },
      "construct": { "htmlFields": ["description"] }
    },
    "Item": {
      "weapon":     { "htmlFields": ["description"] },
      "armour":     { "htmlFields": ["description"] },
      "gear":       { "htmlFields": ["description"] },
      "spell":      { "htmlFields": ["description"] },
      "prayer":     { "htmlFields": ["description"] },
      "gift":       { "htmlFields": ["description"] },
      "talent":     { "htmlFields": ["description"] },
      "gadget":     { "htmlFields": ["description"] },
      "feature":    { "htmlFields": ["description"] },
      "condition":  { "htmlFields": ["description"] },
      "instrument": { "htmlFields": ["description"] },
      "guild":      { "htmlFields": ["description"] }
    }
  },
  "url": "https://github.com/reubentaylor/flail-system",
  "readme": "https://github.com/reubentaylor/flail-system/blob/main/README.md",
  "bugs": "https://github.com/reubentaylor/flail-system/issues",
  "changelog": "https://github.com/reubentaylor/flail-system/releases",
  "manifest": "https://github.com/reubentaylor/flail-system/releases/latest/download/system.json",
  "download": "https://github.com/reubentaylor/flail-system/releases/latest/download/flail.zip"
}
